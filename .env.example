# =============================================================================
# OpenClaw AppFactory -- Environment Variables
# =============================================================================
# Copy this to .env and fill in real values, or let bootstrap.sh generate it.
# NEVER commit the .env file itself.
# =============================================================================

# --- Domain ---
DOMAIN=eitan-openclaw.duckdns.org

# --- DuckDNS (free dynamic DNS) ---
DUCKDNS_SUBDOMAIN=eitan-openclaw
DUCKDNS_TOKEN=your-duckdns-token-from-duckdns.org-dashboard

# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# --- GitHub (for pushing generated apps) ---
GITHUB_TOKEN=ghp_...
GITHUB_USER=eitandooreckaloni

# --- OpenClaw Security ---
# Generated automatically by bootstrap.sh (openssl rand -hex 32)
OPENCLAW_AUTH_TOKEN=generate-me-with-openssl-rand-hex-32
